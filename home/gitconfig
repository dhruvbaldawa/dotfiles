[github]
  user = dhruvbaldawa

[alias]
  st = status
  ci = commit
  br = branch
  co = checkout
  df = diff
  dc = diff --cached
  lg = log -p
  lol = log --graph --decorate --pretty=oneline --abbrev-commit
  lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
  ls = ls-files
  # Show files ignored by git:
  ign = ls-files -o -i --exclude-standard.settings/

  cb = "!sh -c 'git branch $1 && git ch $1' -"
  ctb = "!sh -c 'git cb topics/$1' -"
  cpush = "!sh -c 'git commit -au -m \"$1\" && git push -u origin' -"
  url = !git remote -v|sed "'s|.*git[:@]\\(.*\\).git.*|http://\\1|;s|m:|m/|'"|uniq|xargs open
  whois = "!sh -c 'git log -i -1 --pretty=\"format:%an <%ae>\n\" --author=\"$1\"' -"
  discard = checkout -- .
  rmtag = "!sh -c 'git tag -d $1; git push origin :refs/tags/$1'"

  changelog = !sh "$HOME/Code/dotfiles/git-extras/git-changelog.sh"
  rstatus   = !zsh "$HOME/Code/dotfiles/git-extras/git-rstatus.sh"
  release   = !sh "$HOME/Code/dotfiles/git-extras/git-release.sh"
  setup     = !zsh "$HOME/Code/dotfiles/git-extras/git-setup.sh"
  summary   = !zsh "$HOME/Code/dotfiles/git-extras/git-summary.sh"
  delete-branch = !sh "$HOME/Code/dotfiles/git-extras/git-delete-branch.sh"

  ghpull = !sh "$HOME/Code/dotfiles/git-extras/git-ghpull.sh"
  ghfork = !sh "$HOME/Code/dotfiles/git-extras/git-ghpull.sh"
  cleanup = !ruby "$HOME/Code/dotfiles/git-extras/git-cleanup.rb"

[push]
  default = current

[format]
  pretty = %Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset
  graph = true

[mergetool]
  keepBackup = true

[color]
  ui = always

[apply]
  whitespace = fix

[core]
  excludesfile = ~/.gitignore
  attributesfile = ~/.gitattributes
  whitespace = fix,space-before-tab,tab-in-indent,trailing-space

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[merge]
  log = true

[url "git@github.com:"]
  insteadOf = "gh:"
  pushInsteadOf = "github:"
  pushInsteadOf = "git://github.com/"

[url "git://github.com/"]
  insteadOf = "github:"

[url "git@gist.github.com:"]
  insteadOf = "gst:"
  pushInsteadOf = "gist:"
  pushInsteadOf = "git://gist.github.com/"

[url "git://gist.github.com/"]
  insteadOf = "gist:"

# Any GitHub repo with my username should be checked out r/w by default
# http://rentzsch.tumblr.com/post/564806957/public-but-hackable-git-submodules
[url "git@github.com:dhruvbaldawa/"]
  insteadOf = "git://github.com/dhruvbaldawa/"


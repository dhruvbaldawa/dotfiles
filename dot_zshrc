#
# Executes commands at the start of an interactive session.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Prezto's utility module registers a `make` wrapper for colormake; remove it
# so `make` resolves to the actual binary.
(( $+functions[make] )) && unfunction make

export HISTSIZE=9999999
export HISTFILESIZE=9999999
export SAVEHIST=${HISTSIZE}
export HISTTIMEFORMAT="[%F %T] "
setopt EXTENDED_HISTORY      # Write the history file in the ':start:elapsed;command' format.
setopt INC_APPEND_HISTORY    # Write to the history file immediately, not when the shell exits.
unsetopt SHARE_HISTORY       # Share history between all sessions.
setopt HIST_IGNORE_DUPS      # Do not record an event that was just recorded again.
setopt HIST_IGNORE_ALL_DUPS  # Delete an old recorded event if a new event is a duplicate.
setopt HIST_IGNORE_SPACE     # Do not record an event starting with a space.
setopt HIST_SAVE_NO_DUPS     # Do not write a duplicate event to the history file.
setopt HIST_VERIFY           # Do not execute immediately upon history expansion.
setopt APPEND_HISTORY        # append to history file (Default)
setopt HIST_NO_STORE         # Don't store history commands
setopt HIST_REDUCE_BLANKS    # Remove superfluous blanks from each command line being added to the history.
setopt PROMPT_SP
setopt prompt_subst interactive_comments  # for starship prompt

# Homebrew
export HOMEBREW_NO_AUTO_UPDATE=1
[ -f /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
[ -f /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# fzf: use fd for file/directory discovery, bat/eza for previews
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height=40% --layout=reverse --border'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}'"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_ALT_C_OPTS="--preview 'eza --tree --level=2 --color=always {}'"
source <(fzf --zsh)

# Atuin shell history (binds Up arrow and Ctrl+R)
eval "$(atuin init zsh)"

# Install starship
command -v starship &>/dev/null || sh -c "$(curl -fsSL https://starship.rs/install.sh)"

# Disable the virtualenv prompt.
export VIRTUAL_ENV_DISABLE_PROMPT=1

# fnm (Node version manager)
eval "$(fnm env)"

# zoxide
eval "$(zoxide init zsh)"

# carapace
export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense' # optional
zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
zstyle ':completion:*:git:*' group-order 'main commands' 'alias commands' 'external commands'
source <(carapace _carapace)

# Load plugins via antidote
source "$(brew --prefix antidote)/share/antidote/antidote.zsh"
antidote load
command -v kubectl &>/dev/null && source <(antidote bundle dbz/kube-aliases)

[[ -f "$HOME/aliases.sh" ]] && source $HOME/aliases.sh
[[ -f "$HOME/functions.sh" ]] && source $HOME/functions.sh
[[ -f "$HOME/tools.sh" ]] && source $HOME/tools.sh
[[ -f "$HOME/.extra" ]] && source $HOME/.extra

autoload -Uz compinit
# Rebuild zcompdump at most once per day (zsh glob qualifier: modified >24h ago)
if [[ ! -f "$HOME/.zcompdump" || -n "$HOME/.zcompdump"(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
